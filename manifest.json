{
  "manifest_version": 3,
  "name": "Any Subtitle",
  "version": "0.3.0",
  "description": "Generate private local live or accurate subtitles for the current Chromium tab.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabCapture",
    "offscreen",
    "storage",
    "nativeMessaging"
  ],
  "optional_permissions": [
    "cookies"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "開啟 Any Subtitle",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Open Any Subtitle for the current tab"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/caption-utils.mjs"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
